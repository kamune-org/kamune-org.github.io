---
import { t } from '../lib/i18n';

const { lang } = Astro.props;
const $t = (key: string) => t(lang, key);

const features = [
  { icon: '🔮', title: $t('features.postQuantum.title'), desc: $t('features.postQuantum.desc') },
  { icon: '🔐', title: $t('features.e2e.title'), desc: $t('features.e2e.desc') },
  { icon: '🔗', title: $t('features.p2p.title'), desc: $t('features.p2p.desc') },
  { icon: '⚡', title: $t('features.transport.title'), desc: $t('features.transport.desc') },
  { icon: '🛡️', title: $t('features.forward.title'), desc: $t('features.forward.desc') },
  { icon: '📖', title: $t('features.open.title'), desc: $t('features.open.desc') },
];
---

<section id="features" class="py-20 px-4">
  <div class="max-w-6xl mx-auto">
    <h2 class="section-title">{$t('features.title')}</h2>
    <p class="section-subtitle">{$t('features.subtitle')}</p>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {features.map((f) => (
        <div class="card group">
          <div class="text-3xl mb-4">{f.icon}</div>
          <h3 class="text-lg font-semibold mb-2 group-hover:text-accent transition-colors">{f.title}</h3>
          <p class="text-sm text-text-muted leading-relaxed">{f.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
