---
import { t } from '../lib/i18n';

const { lang } = Astro.props;
const $t = (key: string) => t(lang, key);
---

<footer class="border-t border-border py-8 mt-20">
  <div class="max-w-6xl mx-auto px-4 flex flex-col md:flex-row items-center justify-between gap-4 text-sm text-text-muted">
    <div class="flex items-center gap-2">
      <img src="/logo.png" alt="Kamune" class="h-5 w-5" />
      <span>{$t('footer.builtWith')} <span class="text-accent">♥</span> {$t('footer.by')}</span>
    </div>
    <div class="flex items-center gap-4">
      <a href="https://github.com/kamune-org/kamune/blob/main/LICENSE" target="_blank" rel="noopener noreferrer" class="hover:text-text-primary transition-colors">
        {$t('footer.license')}
      </a>
      <a href="https://github.com/kamune-org/kamune" target="_blank" rel="noopener noreferrer" class="hover:text-text-primary transition-colors">
        GitHub
      </a>
    </div>
  </div>
</footer>
