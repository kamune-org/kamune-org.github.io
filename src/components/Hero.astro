---
import { t } from '../lib/i18n';
import GifPlayer from './GifPlayer.astro';

const { lang } = Astro.props;
const $t = (key: string) => t(lang, key);
const base = lang === 'en' ? '/en' : '/fa';
---

<section class="pt-32 pb-16 px-4">
  <div class="max-w-4xl mx-auto text-center">
    <span class="badge-accent mb-6 inline-block">{$t('hero.version')}</span>
    <h1 class="text-4xl md:text-6xl font-bold tracking-tight mb-6 animate-fade-in">
      {$t('hero.title')}
    </h1>
    <p class="text-lg md:text-xl text-text-muted max-w-3xl mx-auto mb-8 animate-slide-up">
      {$t('hero.subtitle')}
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-12">
      <a
        href="#quick-start"
        class="px-6 py-3 rounded-lg bg-accent text-white font-semibold hover:bg-accent-hover transition-colors"
      >
        {$t('hero.getStarted')}
      </a>
      <a
        href="https://github.com/kamune-org/kamune"
        target="_blank"
        rel="noopener noreferrer"
        class="px-6 py-3 rounded-lg border border-border text-text-secondary font-semibold hover:border-accent/30 hover:text-text-primary transition-colors"
      >
        {$t('hero.viewGithub')}
      </a>
    </div>
    <div class="animate-fade-in">
      <GifPlayer src="/demo.gif" alt="Kamune demo" />
    </div>
  </div>
</section>
