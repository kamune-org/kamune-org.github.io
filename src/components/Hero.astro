---
import { t } from '../lib/i18n';
import VideoPlayer from './VideoPlayer.astro';

const { lang } = Astro.props;
const $t = (key: string) => t(lang, key);
const base = lang === 'en' ? '/' : '/fa';
---

<section class="relative pt-36 pb-16 px-4">
  <div class="hero-glow"></div>
  <div class="relative max-w-4xl mx-auto text-center">
    <div data-reveal="0">
      <span class="badge-accent mb-8 inline-block">{$t('hero.version')}</span>
    </div>
    <h1 class="text-5xl md:text-7xl font-bold tracking-tight leading-[1.1] mb-6 gradient-text" data-reveal="1">
      {$t('hero.title')}
    </h1>
    <p class="text-lg md:text-xl text-text-secondary max-w-2xl mx-auto mb-10 leading-relaxed" data-reveal="2">
      {$t('hero.subtitle')}
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-14" data-reveal="3">
      <a
        href="#quick-start"
        class="px-7 py-3.5 rounded-xl bg-accent text-white font-semibold glow transition-all duration-200 hover:bg-accent-hover hover:shadow-lg hover:-translate-y-0.5"
      >
        {$t('hero.getStarted')}
      </a>
      <a
        href="https://github.com/kamune-org/kamune"
        target="_blank"
        rel="noopener noreferrer"
        class="px-7 py-3.5 rounded-xl border border-border/80 text-text-secondary font-semibold backdrop-blur-sm hover:text-text-primary hover:border-accent/25 hover:bg-accent/5 transition-all duration-200"
      >
        {$t('hero.viewGithub')}
      </a>
    </div>
    <div data-reveal="4">
      <VideoPlayer src="/demo.mp4" alt="Kamune demo" />
    </div>
  </div>
</section>
