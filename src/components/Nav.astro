---
import { t } from '../lib/i18n';

const { lang } = Astro.props;
const $t = (key: string) => t(lang, key);
const base = lang === 'en' ? '/' : '/fa';
const otherLang = lang === 'en' ? 'fa' : 'en';
const otherLabel = lang === 'en' ? 'فارسی' : 'English';
const otherBase = lang === 'en' ? '/fa' : '/';
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-bg/80 backdrop-blur-xl border-b border-border/60">
  <div class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
    <a href={base} class="flex items-center gap-2.5 text-text-primary font-semibold">
      <img src="/logo.png" alt="Kamune" class="h-7 w-7 rounded-md" />
      <span class="text-base">{$t('nav.brand')}</span>
    </a>

    <div class="hidden md:flex items-center gap-1 text-sm text-text-muted">
      <a href={`${base}#features`} class="px-3 py-1.5 rounded-lg hover:text-text-primary hover:bg-accent/5 transition-all duration-150">{$t('nav.features')}</a>
      <a href={`${base}#how-it-works`} class="px-3 py-1.5 rounded-lg hover:text-text-primary hover:bg-accent/5 transition-all duration-150">{$t('nav.howItWorks')}</a>
      <a href={`${base}#modules`} class="px-3 py-1.5 rounded-lg hover:text-text-primary hover:bg-accent/5 transition-all duration-150">{$t('nav.modules')}</a>
      <a href={`${base}#security`} class="px-3 py-1.5 rounded-lg hover:text-text-primary hover:bg-accent/5 transition-all duration-150">{$t('nav.security')}</a>
    </div>

    <div class="flex items-center gap-2">
      <!-- Language switcher -->
      <a
        href={otherBase}
        class="text-xs font-medium px-2.5 py-1.5 rounded-lg border border-border/60 text-text-muted hover:text-text-primary hover:border-accent/20 transition-all duration-150"
      >
        {otherLabel}
      </a>

      <!-- Theme toggle -->
      <button
        type="button"
        data-theme-toggle
        class="flex items-center justify-center w-9 h-9 rounded-lg border border-border/60 text-text-muted hover:text-text-primary hover:border-accent/20 transition-all duration-150"
        aria-label="Toggle theme"
      >
        <svg class="w-[18px] h-[18px] fill-none stroke-current stroke-2 hidden dark:block" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
        </svg>
        <svg class="w-[18px] h-[18px] fill-none stroke-current stroke-2 block dark:hidden" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
      </button>

      <!-- GitHub -->
      <a
        href="https://github.com/kamune-org/kamune"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center justify-center w-9 h-9 rounded-lg border border-border/60 text-text-muted hover:text-text-primary hover:border-accent/20 transition-all duration-150"
        aria-label="GitHub"
      >
        <svg class="w-[18px] h-[18px] fill-current" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
      </a>

      <!-- Hamburger -->
      <button
        class="md:hidden flex items-center justify-center w-9 h-9 rounded-lg border border-border/60 text-text-muted hover:text-text-primary hover:border-accent/20 transition-all duration-150"
        data-hamburger
        type="button"
        aria-label="Menu"
        aria-expanded="false"
      >
        <svg class="w-5 h-5 fill-none stroke-current stroke-2" data-hamburger-open viewBox="0 0 24 24"><path stroke-linecap="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
        <svg class="w-5 h-5 fill-none stroke-current stroke-2 hidden" data-hamburger-close viewBox="0 0 24 24"><path stroke-linecap="round" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div class="md:hidden hidden border-t border-border/60 bg-bg/95 backdrop-blur-xl" data-mobile-menu>
    <div class="max-w-6xl mx-auto px-4 py-3 flex flex-col gap-1 text-sm text-text-muted">
      <a href={`${base}#features`} class="py-2.5 px-3 rounded-lg hover:text-text-primary hover:bg-accent/5 transition-all duration-150">{$t('nav.features')}</a>
      <a href={`${base}#how-it-works`} class="py-2.5 px-3 rounded-lg hover:text-text-primary hover:bg-accent/5 transition-all duration-150">{$t('nav.howItWorks')}</a>
      <a href={`${base}#modules`} class="py-2.5 px-3 rounded-lg hover:text-text-primary hover:bg-accent/5 transition-all duration-150">{$t('nav.modules')}</a>
      <a href={`${base}#security`} class="py-2.5 px-3 rounded-lg hover:text-text-primary hover:bg-accent/5 transition-all duration-150">{$t('nav.security')}</a>
    </div>
  </div>
</nav>

<script>
  // Hamburger menu
  const hamburger = document.querySelector('[data-hamburger]') as HTMLButtonElement;
  const menu = document.querySelector('[data-mobile-menu]') as HTMLElement;
  const openIcon = document.querySelector('[data-hamburger-open]') as SVGSVGElement;
  const closeIcon = document.querySelector('[data-hamburger-close]') as SVGSVGElement;

  hamburger?.addEventListener('click', () => {
    const expanded = hamburger.getAttribute('aria-expanded') === 'true';
    hamburger.setAttribute('aria-expanded', String(!expanded));
    menu?.classList.toggle('hidden');
    openIcon?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
  });

  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
      openIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
      hamburger?.setAttribute('aria-expanded', 'false');
    });
  });

  // Theme toggle
  const toggle = document.querySelector('[data-theme-toggle]') as HTMLButtonElement;
  toggle?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  });
</script>
