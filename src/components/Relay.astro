---
import { t } from '../lib/i18n';

const { lang } = Astro.props;
const $t = (key: string) => t(lang, key);

const properties = [
  { title: $t('relay.blind'), desc: $t('relay.blindDesc') },
  { title: $t('relay.stateless'), desc: $t('relay.statelessDesc') },
  { title: $t('relay.zeroMetadata'), desc: $t('relay.zeroMetadataDesc') },
  { title: $t('relay.transportAgnostic'), desc: $t('relay.transportAgnosticDesc') },
  { title: $t('relay.broker.title'), desc: $t('relay.broker.desc') },
];

const transports = [
  { name: $t('relay.transportTable.ws'), dpi: $t('relay.transportTable.wsDpi'), best: $t('relay.transportTable.wsBest') },
  { name: $t('relay.transportTable.wss'), dpi: $t('relay.transportTable.wssDpi'), best: $t('relay.transportTable.wssBest') },
  { name: $t('relay.transportTable.tcp'), dpi: $t('relay.transportTable.tcpDpi'), best: $t('relay.transportTable.tcpBest') },
  { name: $t('relay.transportTable.tls'), dpi: $t('relay.transportTable.tlsDpi'), best: $t('relay.transportTable.tlsBest') },
];
---

<section class="py-20 px-4">
  <div class="max-w-6xl mx-auto">
    <h2 class="section-title">{$t('relay.title')}</h2>
    <p class="section-subtitle">{$t('relay.subtitle')}</p>

    <div class="flex flex-wrap justify-center gap-6 mb-12">
      {properties.map((p) => (
        <div class="card text-center w-full md:w-[calc(50%-0.75rem)] lg:w-[calc(33.333%-1rem)]">
          <h3 class="font-semibold mb-2 text-accent">{p.title}</h3>
          <p class="text-sm text-text-muted">{p.desc}</p>
        </div>
      ))}
    </div>

    <div class="max-w-2xl mx-auto">
      <h3 class="text-lg font-semibold mb-4 text-center">{$t('relay.transportTable.title')}</h3>
      <div class="card overflow-x-auto p-0">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-border">
              <th class="text-start px-4 py-3 text-text-muted font-medium">{$t('relay.transportTable.transport')}</th>
              <th class="text-start px-4 py-3 text-text-muted font-medium">{$t('relay.transportTable.dpi')}</th>
              <th class="text-start px-4 py-3 text-text-muted font-medium">{$t('relay.transportTable.bestFor')}</th>
            </tr>
          </thead>
          <tbody>
            {transports.map((tr, i) => (
              <tr class={i < transports.length - 1 ? 'border-b border-border' : ''}>
                <td class="px-4 py-3 font-medium">{tr.name}</td>
                <td class="px-4 py-3">
                  <span class={`badge text-[10px] ${
                    tr.dpi === $t('relay.transportTable.wssDpi') || tr.dpi === $t('relay.transportTable.tlsDpi') ? 'bg-success-dim text-success border border-success/30' :
                    tr.dpi === $t('relay.transportTable.wsDpi') ? 'bg-warning-dim text-warning border border-warning/30' :
                    'bg-bg-surface text-text-muted border border-border'
                  }`}>{tr.dpi}</span>
                </td>
                <td class="px-4 py-3 text-text-muted">{tr.best}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>
