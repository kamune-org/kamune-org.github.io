---
import { t } from '../lib/i18n';

const { lang } = Astro.props;
const $t = (key: string) => t(lang, key);

const properties = [
  { title: $t('relay.blind'), desc: $t('relay.blindDesc') },
  { title: $t('relay.stateless'), desc: $t('relay.statelessDesc') },
  { title: $t('relay.zeroMetadata'), desc: $t('relay.zeroMetadataDesc') },
  { title: $t('relay.transportAgnostic'), desc: $t('relay.transportAgnosticDesc') },
  { title: $t('relay.broker.title'), desc: $t('relay.broker.desc') },
];

const transports = [
  { name: $t('relay.transportTable.ws'), dpi: $t('relay.transportTable.wsDpi'), best: $t('relay.transportTable.wsBest') },
  { name: $t('relay.transportTable.wss'), dpi: $t('relay.transportTable.wssDpi'), best: $t('relay.transportTable.wssBest') },
  { name: $t('relay.transportTable.tcp'), dpi: $t('relay.transportTable.tcpDpi'), best: $t('relay.transportTable.tcpBest') },
  { name: $t('relay.transportTable.tls'), dpi: $t('relay.transportTable.tlsDpi'), best: $t('relay.transportTable.tlsBest') },
];
---

<section class="py-24 px-4 bg-bg-surface/50">
  <div class="max-w-6xl mx-auto">
    <h2 class="section-title" data-reveal="0">{$t('relay.title')}</h2>
    <p class="section-subtitle" data-reveal="1">{$t('relay.subtitle')}</p>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 mb-14">
      {properties.map((p, i) => (
        <div class="card text-center" data-reveal={String((i % 3) + 1)}>
          <h3 class="font-semibold mb-2 text-accent">{p.title}</h3>
          <p class="text-sm text-text-secondary leading-relaxed">{p.desc}</p>
        </div>
      ))}
    </div>

    <div class="max-w-2xl mx-auto" data-reveal="2">
      <h3 class="text-lg font-semibold mb-4 text-center">{$t('relay.transportTable.title')}</h3>
      <div class="card overflow-hidden p-0">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-border/60">
              <th class="text-start px-5 py-3.5 text-text-secondary font-medium">{$t('relay.transportTable.transport')}</th>
              <th class="text-start px-5 py-3.5 text-text-secondary font-medium">{$t('relay.transportTable.dpi')}</th>
              <th class="text-start px-5 py-3.5 text-text-secondary font-medium">{$t('relay.transportTable.bestFor')}</th>
            </tr>
          </thead>
          <tbody>
            {transports.map((tr, i) => (
              <tr class={i < transports.length - 1 ? 'border-b border-border/40' : ''}>
                <td class="px-5 py-3.5 font-medium">{tr.name}</td>
                <td class="px-5 py-3.5">
                  <span class={`badge text-[10px] ${
                    tr.dpi === $t('relay.transportTable.wssDpi') || tr.dpi === $t('relay.transportTable.tlsDpi') ? 'bg-success/10 text-success border border-success/20' :
                    tr.dpi === $t('relay.transportTable.wsDpi') ? 'bg-warning/10 text-warning border border-warning/20' :
                    'bg-bg-surface text-text-secondary border border-border/60'
                  }`}>{tr.dpi}</span>
                </td>
                <td class="px-5 py-3.5 text-text-secondary">{tr.best}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>
