---
import { t } from '../lib/i18n';

const { lang } = Astro.props;
const $t = (key: string) => t(lang, key);

const completed = [
  $t('roadmap.item.ping'),
  $t('roadmap.item.qr'),
  $t('roadmap.item.nat'),
  $t('roadmap.item.relay'),
];

const planned = [
  $t('roadmap.item.resumption'),
  $t('roadmap.item.rotation'),
  $t('roadmap.item.quic'),
  $t('roadmap.item.mls'),
  $t('roadmap.item.mobile'),
];
---

<section id="roadmap" class="py-20 px-4">
  <div class="max-w-6xl mx-auto">
    <h2 class="section-title">{$t('roadmap.title')}</h2>
    <p class="section-subtitle">{$t('roadmap.subtitle')}</p>
    <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
      <div class="card">
        <h3 class="text-lg font-semibold mb-4 flex items-center gap-2">
          <span class="badge-success">{$t('roadmap.completed')}</span>
        </h3>
        <ul class="space-y-3">
          {completed.map((item) => (
            <li class="flex items-start gap-3 text-sm text-text-secondary">
              <span class="text-success mt-0.5">✓</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
      <div class="card">
        <h3 class="text-lg font-semibold mb-4 flex items-center gap-2">
          <span class="badge-accent">{$t('roadmap.planned')}</span>
        </h3>
        <ul class="space-y-3">
          {planned.map((item) => (
            <li class="flex items-start gap-3 text-sm text-text-secondary">
              <span class="text-accent mt-0.5">◇</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
