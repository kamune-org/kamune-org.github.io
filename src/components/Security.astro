---
import { t } from '../lib/i18n';

const { lang } = Astro.props;
const $t = (key: string) => t(lang, key);

const properties = [
  { title: $t('security.confidentiality.title'), desc: $t('security.confidentiality.desc'), icon: '🔒' },
  { title: $t('security.integrity.title'), desc: $t('security.integrity.desc'), icon: '✅' },
  { title: $t('security.auth.title'), desc: $t('security.auth.desc'), icon: '🪪' },
  { title: $t('security.forward.title'), desc: $t('security.forward.desc'), icon: '🔄' },
  { title: $t('security.postQuantum.title'), desc: $t('security.postQuantum.desc'), icon: '🔮' },
  { title: $t('security.replay.title'), desc: $t('security.replay.desc'), icon: '🔁' },
  { title: $t('security.traffic.title'), desc: $t('security.traffic.desc'), icon: '🎭' },
];
---

<section id="security" class="py-20 px-4 bg-bg-surface">
  <div class="max-w-6xl mx-auto">
    <h2 class="section-title">{$t('security.title')}</h2>
    <p class="section-subtitle">{$t('security.subtitle')}</p>
    <div class="flex flex-wrap justify-center gap-6">
      {properties.map((p) => (
        <div class="card group flex items-start gap-4 w-full md:w-[calc(50%-0.75rem)] lg:w-[calc(33.333%-1rem)]">
          <span class="text-2xl mt-1">{p.icon}</span>
          <div>
            <h3 class="font-semibold mb-1 group-hover:text-accent transition-colors">{p.title}</h3>
            <p class="text-sm text-text-muted leading-relaxed">{p.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
