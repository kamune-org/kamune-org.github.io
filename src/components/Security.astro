  {
    title: $t('security.traffic.title'),
    desc: $t('security.traffic.desc'),
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88" /></svg>`,
  },
];
---

<section id="security" class="py-24 px-4">
  <div class="max-w-6xl mx-auto">
    <h2 class="section-title" data-reveal="0">{$t('security.title')}</h2>
    <p class="section-subtitle" data-reveal="1">{$t('security.subtitle')}</p>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {properties.map((p, i) => (
        <div class="card group flex items-start gap-4" data-reveal={String((i % 3) + 1)}>
          <div class="flex-shrink-0 w-10 h-10 rounded-xl bg-accent/10 text-accent flex items-center justify-center group-hover:bg-accent/15 transition-colors duration-200">
            <Fragment set:html={p.icon} />
          </div>
          <div>
            <h3 class="font-semibold mb-1 group-hover:text-accent transition-colors duration-200">{p.title}</h3>
            <p class="text-sm text-text-secondary leading-relaxed">{p.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
