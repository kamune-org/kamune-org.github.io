---
const { src = '/demo.mp4', poster = '/poster.jpg', alt = 'Kamune demo' } = Astro.props;
---

<div class="relative group rounded-2xl border border-border/60 overflow-hidden bg-bg-surface shadow-card" data-player dir="ltr">
  <video
    {src}
    {poster}
    loop
    muted
    playsinline
    preload="metadata"
    class="w-full block cursor-pointer"
    aria-label={alt}
    data-video
  />

  <!-- Centered play button -->
  <button
    class="absolute inset-0 flex items-center justify-center z-10 transition-opacity duration-200"
    data-center-play
    type="button"
    aria-label="Play"
  >
    <span class="bg-accent/90 backdrop-blur-sm rounded-full w-18 h-18 flex items-center justify-center text-white text-2xl transition-all duration-200 hover:scale-110 glow" style="width: 4.5rem; height: 4.5rem;">
      <svg class="w-7 h-7 fill-current ml-1" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
    </span>
  </button>

  <!-- Bottom controls -->
  <div
    class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent pt-10 pb-4 px-4 transition-opacity duration-300 z-20"
    data-controls
  >
    <!-- Progress bar -->
    <div
      class="w-full h-1.5 bg-white/20 rounded-full mb-3 cursor-pointer group/progress"
      data-progress-bar
      role="slider"
      aria-label="Seek"
      aria-valuemin="0"
      aria-valuemax="100"
      aria-valuenow="0"
    >
      <div
        class="h-full rounded-full relative transition-[width] duration-100"
        style="background: linear-gradient(90deg, rgb(99 102 241), #8b5cf6);"
        data-progress-fill
      >
        <span class="absolute right-0 top-1/2 -translate-y-1/2 w-3.5 h-3.5 bg-white rounded-full opacity-0 group-hover/progress:opacity-100 transition-opacity shadow-md" />
      </div>
    </div>

    <div class="flex items-center gap-3">
      <!-- Play / Pause -->
      <button class="text-white/80 hover:text-white transition-colors duration-150" data-play-btn type="button" aria-label="Play">
        <svg class="w-6 h-6 fill-current" data-play-icon viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
        <svg class="w-6 h-6 fill-current hidden" data-pause-icon viewBox="0 0 24 24"><path d="M6 19h4V5H6zm8-14v14h4V5z"/></svg>
      </button>

      <!-- Time -->
      <span class="text-sm text-white/70 font-mono tabular-nums" data-time>0:00</span>

      <div class="flex-1" />

      <!-- Fullscreen -->
      <button class="text-white/80 hover:text-white transition-colors duration-150" data-fullscreen-btn type="button" aria-label="Fullscreen">
        <svg class="w-5 h-5 fill-current" data-fs-enter viewBox="0 0 24 24"><path d="M7 14H5v5h5v-2H7v-3zm-2-4h2V7h3V5H5v5zm12 7h-3v2h5v-5h-2v3zM14 5v2h3v3h2V5h-5z"/></svg>
        <svg class="w-5 h-5 fill-current hidden" data-fs-exit viewBox="0 0 24 24"><path d="M5 16h3v3h2v-5H5v2zm3-8H5v2h5V5H8v3zm6 11h2v-3h3v-2h-5v5zm2-11V5h-2v5h5V8h-3z"/></svg>
      </button>
    </div>
  </div>
</div>

<script>
  document.querySelectorAll('[data-player]').forEach((root) => {
    const video = root.querySelector('[data-video]') as HTMLVideoElement;
    const centerPlay = root.querySelector('[data-center-play]') as HTMLElement;
    const controls = root.querySelector('[data-controls]') as HTMLElement;
    const playBtn = root.querySelector('[data-play-btn]') as HTMLButtonElement;
    const playIcon = root.querySelector('[data-play-icon]') as SVGSVGElement;
    const pauseIcon = root.querySelector('[data-pause-icon]') as SVGSVGElement;
    const timeEl = root.querySelector('[data-time]') as HTMLElement;
    const progressBar = root.querySelector('[data-progress-bar]') as HTMLElement;
    const progressFill = root.querySelector('[data-progress-fill]') as HTMLElement;
    const fsBtn = root.querySelector('[data-fullscreen-btn]') as HTMLButtonElement;
    const fsEnter = root.querySelector('[data-fs-enter]') as SVGSVGElement;
    const fsExit = root.querySelector('[data-fs-exit]') as SVGSVGElement;

    let hideTimer: ReturnType<typeof setTimeout>;

    const fmt = (s: number) => {
      const m = Math.floor(s / 60);
      const sec = Math.floor(s % 60);
      return `${m}:${sec.toString().padStart(2, '0')}`;
    };

    const updateIcons = () => {
      const paused = video.paused;
      playIcon.classList.toggle('hidden', !paused);
      pauseIcon.classList.toggle('hidden', paused);
      centerPlay.style.opacity = paused ? '1' : '0';
      centerPlay.style.pointerEvents = paused ? 'auto' : 'none';
      playBtn.setAttribute('aria-label', paused ? 'Play' : 'Pause');
    };

    const togglePlay = () => {
      video.paused ? video.play() : video.pause();
    };

    const showControls = () => {
      controls.style.opacity = '1';
      clearTimeout(hideTimer);
      hideTimer = setTimeout(() => {
        if (!video.paused) controls.style.opacity = '0';
      }, 3000);
    };

    video.addEventListener('click', togglePlay);
    centerPlay.addEventListener('click', (e) => { e.stopPropagation(); togglePlay(); });
    playBtn.addEventListener('click', togglePlay);

    video.addEventListener('play', updateIcons);
    video.addEventListener('pause', updateIcons);
    video.addEventListener('loadedmetadata', () => {
      timeEl.textContent = `0:00 / ${fmt(video.duration)}`;
    });
    video.addEventListener('timeupdate', () => {
      if (!video.duration) return;
      const pct = (video.currentTime / video.duration) * 100;
      progressFill.style.width = `${pct}%`;
      timeEl.textContent = `${fmt(video.currentTime)} / ${fmt(video.duration)}`;
      progressBar.setAttribute('aria-valuenow', String(Math.round(pct)));
    });

    progressBar.addEventListener('click', (e) => {
      const rect = progressBar.getBoundingClientRect();
      video.currentTime = ((e.clientX - rect.left) / rect.width) * video.duration;
    });

    const updateFsIcon = () => {
      const isFs = !!document.fullscreenElement;
      fsEnter.classList.toggle('hidden', isFs);
      fsExit.classList.toggle('hidden', !isFs);
    };

    fsBtn.addEventListener('click', () => {
      if (document.fullscreenElement) {
        document.exitFullscreen();
      } else {
        root.requestFullscreen();
      }
    });

    document.addEventListener('fullscreenchange', updateFsIcon);

    root.addEventListener('mousemove', showControls);
    root.addEventListener('mouseleave', () => {
      clearTimeout(hideTimer);
      if (!video.paused) controls.style.opacity = '0';
    });

    controls.style.opacity = '0';
  });
</script>
