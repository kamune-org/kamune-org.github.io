---
const { src = '/demo.mp4', poster = '/poster.jpg', alt = 'Kamune demo' } = Astro.props;
---

<div
  class="relative group rounded-2xl border border-border/60 overflow-hidden bg-bg-surface shadow-card outline-none"
  data-player
  dir="ltr"
  role="region"
  aria-label="Video player"
  tabindex="0"
>
  <video
    {src}
    {poster}
    loop
    muted
    playsinline
    preload="metadata"
    class="w-full block cursor-pointer"
    aria-label={alt}
    data-video
  />

  <!-- Buffering spinner -->
  <div
    class="absolute inset-0 flex items-center justify-center z-10 pointer-events-none hidden"
    data-buffering
  >
    <div class="w-10 h-10 border-[3px] border-white/30 border-t-white rounded-full animate-spin" />
  </div>

  <!-- Centered play button -->
  <button
    class="absolute inset-0 flex items-center justify-center z-10 transition-opacity duration-200"
    data-center-play
    type="button"
    aria-label="Play"
  >
    <span class="bg-accent/90 backdrop-blur-sm rounded-full w-18 h-18 flex items-center justify-center text-white text-2xl transition-all duration-200 hover:scale-110 glow" style="width: 4.5rem; height: 4.5rem;">
      <svg class="w-7 h-7 fill-current ml-1" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
    </span>
  </button>

  <!-- Speed indicator -->
  <div
    class="absolute inset-0 flex items-center justify-center pointer-events-none opacity-0 transition-opacity duration-150 z-10"
    data-speed-indicator
  >
    <span class="bg-black/30 backdrop-blur-sm text-white/80 text-lg font-semibold px-4 py-2 rounded-xl">2x</span>
  </div>

  <!-- Bottom controls -->
  <div
    class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent pt-3 pb-2 px-4 transition-opacity duration-300 z-20 cursor-pointer"
    data-controls
  >
    <!-- Progress bar (44px touch target, thin visual track) -->
    <div
      class="w-full h-11 flex items-center cursor-pointer group/progress"
      data-progress-bar
      role="slider"
      aria-label="Seek"
      aria-valuemin="0"
      aria-valuemax="100"
      aria-valuenow="0"
      style="touch-action: none;"
    >
      <div class="w-full h-1.5 bg-white/20 rounded-full relative overflow-visible">
        <div
          class="h-full rounded-full relative transition-[width] duration-0"
          style="background: linear-gradient(90deg, rgb(99 102 241), #8b5cf6);"
          data-progress-fill
        >
          <span class="absolute right-0 top-1/2 -translate-y-1/2 w-3.5 h-3.5 bg-white rounded-full opacity-0 group-hover/progress:opacity-100 group-active/progress:opacity-100 transition-opacity shadow-md" data-thumb />
        </div>
      </div>
    </div>

    <div class="flex items-center gap-3">
      <!-- Play / Pause -->
      <button class="text-white/80 hover:text-white transition-colors duration-150" data-play-btn type="button" aria-label="Play">
        <svg class="w-6 h-6 fill-current" data-play-icon viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
        <svg class="w-6 h-6 fill-current hidden" data-pause-icon viewBox="0 0 24 24"><path d="M6 19h4V5H6zm8-14v14h4V5z"/></svg>
      </button>

      <!-- Time -->
      <span class="text-sm text-white/70 font-mono tabular-nums" data-time>0:00</span>

      <div class="flex-1" />

      <!-- Fullscreen -->
      <button class="text-white/80 hover:text-white transition-colors duration-150" data-fullscreen-btn type="button" aria-label="Fullscreen">
        <svg class="w-5 h-5 fill-current" data-fs-enter viewBox="0 0 24 24"><path d="M7 14H5v5h5v-2H7v-3zm-2-4h2V7h3V5H5v5zm12 7h-3v2h5v-5h-2v3zM14 5v2h3v3h2V5h-5z"/></svg>
        <svg class="w-5 h-5 fill-current hidden" data-fs-exit viewBox="0 0 24 24"><path d="M5 16h3v3h2v-5H5v2zm3-8H5v2h5V5H8v3zm6 11h2v-3h3v-2h-5v5zm2-11V5h-2v5h5V8h-3z"/></svg>
      </button>
    </div>
  </div>
</div>

<style>
  [data-player]:fullscreen,
  [data-player].is-fullscreen {
    display: flex;
    align-items: center;
    justify-content: center;
    background: #000;
    border-radius: 0;
    border: none;
  }

  [data-player]:fullscreen video,
  [data-player].is-fullscreen video {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  [data-player]:fullscreen .absolute,
  [data-player].is-fullscreen .absolute {
    position: absolute;
  }

  [data-player]:fullscreen [data-controls],
  [data-player].is-fullscreen [data-controls] {
    left: 0;
    right: 0;
    bottom: 0;
  }

  [data-player].dragging [data-thumb] {
    opacity: 1;
  }
</style>

<script>
  document.querySelectorAll('[data-player]').forEach((root) => {
    const video = root.querySelector('[data-video]') as HTMLVideoElement;
    const centerPlay = root.querySelector('[data-center-play]') as HTMLElement;
    const controls = root.querySelector('[data-controls]') as HTMLElement;
    const buffering = root.querySelector('[data-buffering]') as HTMLElement;
    const speedIndicator = root.querySelector('[data-speed-indicator]') as HTMLElement;
    const playBtn = root.querySelector('[data-play-btn]') as HTMLButtonElement;
    const playIcon = root.querySelector('[data-play-icon]') as SVGSVGElement;
    const pauseIcon = root.querySelector('[data-pause-icon]') as SVGSVGElement;
    const timeEl = root.querySelector('[data-time]') as HTMLElement;
    const progressBar = root.querySelector('[data-progress-bar]') as HTMLElement;
    const progressFill = root.querySelector('[data-progress-fill]') as HTMLElement;
    const fsBtn = root.querySelector('[data-fullscreen-btn]') as HTMLButtonElement;
    const fsEnter = root.querySelector('[data-fs-enter]') as SVGSVGElement;
    const fsExit = root.querySelector('[data-fs-exit]') as SVGSVGElement;

    let hideTimer: ReturnType<typeof setTimeout>;
    let seeking = false;
    let holdTimer: ReturnType<typeof setTimeout> | null = null;
    let fastForwarding = false;
    let heldRightHalf = false;

    const fmt = (s: number) => {
      const m = Math.floor(s / 60);
      const sec = Math.floor(s % 60);
      return `${m}:${sec.toString().padStart(2, '0')}`;
    };

    const updateIcons = () => {
      const paused = video.paused;
      playIcon.classList.toggle('hidden', !paused);
      pauseIcon.classList.toggle('hidden', paused);
      centerPlay.style.opacity = paused ? '1' : '0';
      centerPlay.style.pointerEvents = paused ? 'auto' : 'none';
      playBtn.setAttribute('aria-label', paused ? 'Play' : 'Pause');
    };

    const togglePlay = () => {
      video.paused ? video.play().catch(() => {}) : video.pause();
    };

    // Clicking the gradient background (not children) toggles play/pause
    controls.addEventListener('click', (e) => {
      if (e.target === controls) togglePlay();
    });

    const showControls = () => {
      controls.style.opacity = '1';
      controls.style.pointerEvents = '';
      clearTimeout(hideTimer);
      hideTimer = setTimeout(() => {
        if (!video.paused) {
          controls.style.opacity = '0';
          controls.style.pointerEvents = 'none';
        }
      }, 3000);
    };

    const seekToClientX = (clientX: number) => {
      const rect = progressBar.getBoundingClientRect();
      const pct = Math.min(Math.max((clientX - rect.left) / rect.width, 0), 1);
      video.currentTime = pct * video.duration;
    };

    // Hold-to-fast-forward on right half of video
    const stopFastForward = () => {
      if (fastForwarding) {
        video.playbackRate = 1;
        speedIndicator.style.opacity = '0';
        fastForwarding = false;
      }
      if (holdTimer) {
        clearTimeout(holdTimer);
        holdTimer = null;
      }
    };

    video.addEventListener('pointerdown', (e) => {
      const rect = video.getBoundingClientRect();
      const isRightHalf = e.clientX > rect.left + rect.width / 2;
      heldRightHalf = isRightHalf;

      if (!isRightHalf || video.paused) return;

      holdTimer = setTimeout(() => {
        holdTimer = null;
        fastForwarding = true;
        video.playbackRate = 2;
        speedIndicator.style.opacity = '1';
      }, 300);
    });

    video.addEventListener('pointerup', () => {
      if (fastForwarding) {
        stopFastForward();
        return;
      }
      if (heldRightHalf && holdTimer) {
        clearTimeout(holdTimer);
        holdTimer = null;
      }
      togglePlay();
    });

    video.addEventListener('pointercancel', stopFastForward);
    video.addEventListener('pointerleave', () => {
      stopFastForward();
      heldRightHalf = false;
    });

    centerPlay.addEventListener('click', (e) => { e.stopPropagation(); togglePlay(); });
    playBtn.addEventListener('click', togglePlay);

    video.addEventListener('play', updateIcons);
    video.addEventListener('pause', updateIcons);
    video.addEventListener('loadedmetadata', () => {
      timeEl.textContent = `0:00 / ${fmt(video.duration)}`;
    });
    video.addEventListener('timeupdate', () => {
      if (!video.duration) return;
      const pct = (video.currentTime / video.duration) * 100;
      progressFill.style.width = `${pct}%`;
      timeEl.textContent = `${fmt(video.currentTime)} / ${fmt(video.duration)}`;
      progressBar.setAttribute('aria-valuenow', String(Math.round(pct)));
    });

    // Drag-to-seek via pointer events
    progressBar.addEventListener('pointerdown', (e) => {
      e.preventDefault();
      seeking = true;
      root.classList.add('dragging');
      progressBar.setPointerCapture(e.pointerId);
      seekToClientX(e.clientX);
    });

    progressBar.addEventListener('pointermove', (e) => {
      if (!seeking) return;
      seekToClientX(e.clientX);
    });

    const stopSeek = () => {
      seeking = false;
      root.classList.remove('dragging');
    };

    progressBar.addEventListener('pointerup', stopSeek);
    progressBar.addEventListener('pointercancel', stopSeek);
    progressBar.addEventListener('lostpointercapture', stopSeek);

    // Keyboard controls
    root.addEventListener('keydown', (e) => {
      const ev = e as KeyboardEvent;
      if (ev.key === ' ' || ev.key === 'k') {
        ev.preventDefault();
        togglePlay();
        showControls();
      } else if (ev.key === 'ArrowLeft') {
        ev.preventDefault();
        video.currentTime = Math.max(video.currentTime - 5, 0);
        showControls();
      } else if (ev.key === 'ArrowRight') {
        ev.preventDefault();
        video.currentTime = Math.min(video.currentTime + 5, video.duration || 0);
        showControls();
      }
    });

    // Buffering indicator
    video.addEventListener('waiting', () => {
      buffering.classList.remove('hidden');
    });
    video.addEventListener('playing', () => {
      buffering.classList.add('hidden');
    });
    video.addEventListener('canplay', () => {
      buffering.classList.add('hidden');
    });

    const updateFsIcon = () => {
      const isFs = !!document.fullscreenElement;
      fsEnter.classList.toggle('hidden', isFs);
      fsExit.classList.toggle('hidden', !isFs);
      root.classList.toggle('is-fullscreen', isFs);
    };

    fsBtn.addEventListener('click', () => {
      if (document.fullscreenElement) {
        document.exitFullscreen();
      } else {
        root.requestFullscreen();
      }
    });

    document.addEventListener('fullscreenchange', () => {
      updateFsIcon();
      if (document.fullscreenElement) {
        (screen.orientation as any)?.lock?.('landscape').catch(() => {});
      } else {
        (screen.orientation as any)?.unlock?.();
      }
    });

    root.addEventListener('mousemove', showControls);
    root.addEventListener('mouseleave', () => {
      clearTimeout(hideTimer);
      if (!video.paused) {
        controls.style.opacity = '0';
        controls.style.pointerEvents = 'none';
      }
    });

    controls.style.opacity = '0';
    controls.style.pointerEvents = 'none';
  });
</script>
