---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Download from '../components/Download.astro';
import Features from '../components/Features.astro';
import CipherSuite from '../components/CipherSuite.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Modules from '../components/Modules.astro';
import Relay from '../components/Relay.astro';
import Security from '../components/Security.astro';
import QuickStart from '../components/QuickStart.astro';
import { t } from '../lib/i18n';

const description = t('en', 'meta.description');
---

<Layout title="Kamune — Messaging built for privacy, by design" lang="en" description={description}>
  <Hero lang="en" />
  <Download lang="en" />
  <QuickStart lang="en" />
  <Features lang="en" />
  <CipherSuite lang="en" />
  <HowItWorks lang="en" />
  <Modules lang="en" />
  <Relay lang="en" />
  <Security lang="en" />
</Layout>
